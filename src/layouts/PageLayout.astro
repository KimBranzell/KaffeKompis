---
// import { pwaInfo } from 'virtual:pwa-info';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '@fontsource-variable/archivo';
import '@/styles/styles.css';

export interface Props {
	title: string;
  description?: string;
}

const base = import.meta.env.BASE_URL;
const { title, description = 'Verktyg, recept och guider for battre handbryggt kaffe hemma.' } = Astro.props;
const pageTitle = `${title} | Kaffekompis`;
---
<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} sizes="180x180">
    <link rel="mask-icon" href={`${base}mask-icon.svg`} color="#FFFFFF">
    <meta name="theme-color" content="#fff8e8">
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{ pageTitle }</title>
    <!-- { pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} /> } -->
  </head>
  <body>
    <a href="#main-content" class="skip-link">Hoppa till innehållet</a>
    <Header />
    <main id="main-content" role="main" class="page-layout">
        <slot />
    </main>
    <Footer role="contentinfo" />
  </body>
</html>