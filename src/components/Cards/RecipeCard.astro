
---
const { title, method, difficulty, time, slug, link, description } = Astro.props;
const href = link ?? `/recept/${slug}/`;

const methodColors = {
  'pour-over': 'bg-[#ffa45b]',
  aeropress: 'bg-[#7cb9e8]',
  'french-press': 'bg-[#c1ff9b]'
};

const methodLabels = {
  'pour-over': 'Pour over',
  aeropress: 'AeroPress',
  'french-press': 'French press'
};
---

<article class="flex h-full flex-col justify-between border-3 border-black bg-white p-6 shadow-[6px_6px_0_#000]">
  <div class="space-y-4">
    <div class="flex flex-wrap gap-2 text-sm font-black uppercase tracking-[0.12em]">
      <span class={`${methodColors[method]} border-2 border-black px-3 py-1`}>
        {methodLabels[method]}
      </span>
      <span class="border-2 border-black bg-[#f2f2f2] px-3 py-1">
        {time}
      </span>
      <span class="border-2 border-black bg-[#fff7ed] px-3 py-1">
        {difficulty}
      </span>
    </div>

    <div class="space-y-3">
      <h3 class="text-2xl font-black leading-tight">{title}</h3>
      {description && <p class="text-base leading-7 text-black/80">{description}</p>}
    </div>
  </div>

  <a href={href} class="mt-6 inline-flex w-fit border-3 border-black bg-black px-4 py-3 text-sm font-black uppercase tracking-[0.16em] text-white transition-transform hover:-translate-y-1">
    Se recept
  </a>
</article>
